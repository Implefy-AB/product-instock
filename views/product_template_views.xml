<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Badge on Product Form View -->
    <record id="product_template_form_view_instock" model="ir.ui.view">
        <field name="name">product.template.form.instock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="is_in_stock" invisible="1"/>
                <div class="badge text-bg-success float-end me-2 mt-2 fs-6"
                     invisible="not is_in_stock">
                    I lager
                </div>
            </xpath>
        </field>
    </record>

    <!-- Badge on Product Kanban View -->
    <record id="product_template_kanban_view_instock" model="ir.ui.view">
        <field name="name">product.template.kanban.instock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//templates//t[@t-name='card']" position="inside">
                <field name="is_in_stock" invisible="1"/>
                <div class="badge text-bg-success mt-1"
                     invisible="not is_in_stock">
                    I lager
                </div>
            </xpath>
        </field>
    </record>

</odoo>
