<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Initial server-side "I lager" badge (JS takes over on variant change) -->
    <template id="product_instock_badge"
              inherit_id="website_sale_stock.product_availability"
              name="Product In Stock Badge">
        <xpath expr="//div[hasclass('availability_messages')]" position="inside">
            <t t-set="product_variant" t-value="product_variant or product.product_variant_id"/>
            <t t-if="product_variant.qty_available &gt; 0">
                <div class="product_instock_badge">
                    <span class="badge text-bg-success">
                        <i class="fa fa-circle me-2 text-success"/>I lager
                    </span>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
