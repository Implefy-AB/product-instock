<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Extend website_sale_stock availability template to add "I lager" badge -->
    <t t-name="product_instock.in_stock_badge"
       t-inherit="website_sale_stock.product_availability"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('availability_messages')]" position="inside">
            <div t-if="free_qty &gt; 0 and !allow_out_of_stock_order"
                 t-att-class="'availability_message_' + product_template">
                <span class="badge text-bg-success">
                    <i class="fa fa-circle me-2 text-success"/>I lager
                </span>
            </div>
        </xpath>
    </t>

</templates>
